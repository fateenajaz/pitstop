# Convex production backend
# Set these with `npx convex env set KEY value` or in the Convex dashboard.
ANTHROPIC_API_KEY=
AUTH_SECRET=replace-with-at-least-32-random-characters
ANTHROPIC_INVESTIGATION_MODEL=claude-opus-4-1-20250805
ANTHROPIC_FOLLOW_UP_MODEL=claude-opus-4-1-20250805
PASSWORD_HASH_ITERATIONS=210000
SESSION_TTL_MS=2592000000
CLIENT_ORIGIN=https://your-vercel-app.vercel.app
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=80
AI_RATE_LIMIT_MAX_REQUESTS=12

# Vercel frontend
# Set this in Vercel Project Settings -> Environment Variables.
# HTTP actions use the .convex.site URL, not the .convex.cloud URL.
VITE_API_URL=https://kindhearted-mongoose-684.convex.site
